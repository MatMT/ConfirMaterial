---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { supabase } from "../utils/supabase";
import { Icon } from "astro-icon/components";

const { cookies, redirect, url } = Astro;
const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");
const successMsg = url.searchParams.get("success");
const errorMsg = url.searchParams.get("error");

if (!accessToken || !refreshToken) {
  return redirect("/login");
}

const { data, error } = await supabase.auth.setSession({
  access_token: accessToken.value,
  refresh_token: refreshToken.value,
});

if (error) {
  cookies.delete("sb-access-token", { path: "/" });
  cookies.delete("sb-refresh-token", { path: "/" });
  return redirect("/login");
}

const user = data?.user;

// Obtener los datos del perfil
let profile = null;
if (user) {
  const { data: profileData } = await supabase
    .from("profiles")
    .select("*")
    .eq("id", user.id)
    .single();

  profile = profileData || {
    first_name: user.user_metadata?.first_name || "",
    last_names: user.user_metadata?.last_names || "",
    credential: user.user_metadata?.credential || "",
    birth_date: user.user_metadata?.birth_date || "",
  };
}
---

<!doctype html>
<html lang="es" data-theme="confirtheme">
  <head>
    <BaseHead
      title={`Dashboard | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />
  </head>
  <body class="min-h-screen bg-base-200">
    <Header />

    <main class="container mx-auto p-4 max-w-4xl animate-fade-up my-8">
      {
        successMsg && (
          <div class="toast toast-top toast-end z-[100]">
            <div class="alert alert-success shadow-lg text-white border-none">
              <Icon name="mdi:check-circle" class="w-6 h-6" />
              <span class="font-medium">{successMsg}</span>
            </div>
          </div>
        )
      }

      {
        errorMsg && (
          <div class="toast toast-top toast-end z-[100]">
            <div class="alert alert-error shadow-lg text-white border-none">
              <Icon name="mdi:alert-circle" class="w-6 h-6" />
              <span class="font-medium">{errorMsg}</span>
            </div>
          </div>
        )
      }

      <div
        class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 sm:gap-4 mb-8 bg-base-100 p-6 rounded-2xl shadow-sm"
      >
        <div class="flex items-center gap-4 w-full min-w-0">
          <div class="avatar placeholder shrink-0">
            <div
              class="bg-primary text-primary-content rounded-full w-14 sm:w-16"
            >
              <span class="text-xl sm:text-2xl"
                >{profile?.first_name?.charAt(0) || "U"}</span
              >
            </div>
          </div>
          <div class="flex flex-col min-w-0 w-full">
            <h1
              class="text-2xl sm:text-3xl font-bold break-words w-full leading-tight"
              id="dashboardTitle"
            >
              Hola, {profile?.first_name || "Usuario"}
            </h1>
            <span
              class="badge badge-accent mt-2 sm:mt-1 whitespace-nowrap overflow-hidden text-ellipsis max-w-full"
              id="dashboardCredential"
              >Credencial: {profile?.credential || "N/A"}</span
            >
          </div>
        </div>
        <a
          href="/api/auth/signout"
          class="btn btn-error btn-outline shadow-sm w-full sm:w-auto shrink-0"
          onclick="localStorage.clear();"
        >
          <Icon name="mdi:logout" class="w-5 h-5 mr-1" />
          Cerrar Sesión
        </a>
      </div>

      <div class="bg-base-100 shadow-xl rounded-2xl overflow-hidden">
        <div role="tablist" class="tabs tabs-bordered p-4">
          {/* TAB 1: Datos Personales */}
          <input
            type="radio"
            name="dashboard_tabs"
            role="tab"
            class="tab font-bold text-sm sm:text-base whitespace-nowrap px-4"
            aria-label="Tus Datos"
            checked
          />
          <div role="tabpanel" class="tab-content p-6 border-t-0 mt-4">
            <form
              action="/api/auth/update-profile"
              method="POST"
              class="max-w-2xl"
              id="profile-form"
            >
              <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                <Icon
                  name="mdi:card-account-details-outline"
                  class="w-6 h-6 text-primary"
                />
                Edita tus datos
              </h2>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control">
                  <label class="label"
                    ><span class="label-text font-semibold">Nombre(s)</span
                    ></label
                  >
                  <input
                    type="text"
                    name="firstName"
                    id="firstNameInput"
                    value={profile?.first_name || ""}
                    class="input input-bordered w-full"
                    required
                  />
                </div>

                <div class="form-control">
                  <label class="label"
                    ><span class="label-text font-semibold">Apellidos</span
                    ></label
                  >
                  <input
                    type="text"
                    name="lastNames"
                    id="lastNamesInput"
                    value={profile?.last_names || ""}
                    class="input input-bordered w-full"
                    required
                  />
                </div>

                <div class="form-control">
                  <label class="label"
                    ><span class="label-text font-semibold"
                      >Fecha de Nacimiento</span
                    ></label
                  >
                  <input
                    type="date"
                    name="birthDate"
                    id="birthDateInput"
                    value={profile?.birth_date || ""}
                    class="input input-bordered w-full"
                    required
                  />
                </div>

                <div class="form-control">
                  <label class="label"
                    ><span class="label-text font-semibold"
                      >Correo Electrónico</span
                    ></label
                  >
                  <input
                    type="text"
                    value={user?.email || ""}
                    class="input input-bordered w-full opacity-60"
                    disabled
                  />
                  <label class="label"
                    ><span class="label-text-alt">No modificable por ahora</span
                    ></label
                  >
                </div>
              </div>

              <div class="mt-8 flex justify-end">
                <button type="submit" class="btn btn-primary w-full shadow-md">
                  <Icon name="mdi:content-save" class="w-5 h-5 mr-2" />
                  Guardar Cambios
                </button>
              </div>
            </form>
          </div>

          {/* TAB 2: Seguridad / Ayuda */}
          <input
            type="radio"
            name="dashboard_tabs"
            role="tab"
            class="tab font-bold text-sm sm:text-base whitespace-nowrap px-4"
            aria-label="Contraseña y Ayuda"
          />
          <div role="tabpanel" class="tab-content p-6 border-t-0 mt-4">
            <div class="max-w-2xl">
              <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                <Icon name="mdi:shield-account" class="w-6 h-6 text-primary" />
                Seguridad de tu Cuenta
              </h2>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Formulario de Cambio de Contraseña -->
                <div class="card bg-base-100 shadow-sm border border-base-200">
                  <div class="card-body p-5">
                    <h3 class="card-title text-lg mb-2">
                      <Icon
                        name="mdi:lock-reset"
                        class="w-5 h-5 text-primary"
                      />
                      Cambiar Contraseña
                    </h3>
                    <form action="/api/auth/update-password" method="POST">
                      <div class="form-control mb-3">
                        <label class="label"
                          ><span class="label-text font-semibold"
                            >Nueva Contraseña</span
                          ></label
                        >
                        <input
                          type="password"
                          name="newPassword"
                          class="input input-bordered w-full"
                          minlength="6"
                          required
                        />
                      </div>
                      <div class="form-control mb-5">
                        <label class="label"
                          ><span class="label-text font-semibold"
                            >Confirmar Contraseña</span
                          ></label
                        >
                        <input
                          type="password"
                          name="confirmPassword"
                          class="input input-bordered w-full"
                          minlength="6"
                          required
                        />
                      </div>
                      <button type="submit" class="btn btn-primary w-full">
                        <Icon name="mdi:lock-check" class="w-5 h-5 mr-1" /> Actualizar
                        Contraseña
                      </button>
                    </form>
                  </div>
                </div>

                <!-- Botón de WhatsApp -->
                <div class="card bg-base-100 shadow-sm border border-base-200 h-fit">
                  <div class="card-body p-5">
                    <h3 class="card-title text-base-content text-lg">
                      <Icon name="mdi:whatsapp" class="w-6 h-6 text-green-500" />
                      Soporte y Ayuda
                    </h3>
                    <p class="text-base-content/70 text-sm mt-1 mb-4 leading-relaxed">
                      ¿Tienes problemas u olvidaste algo? Escríbenos
                      directamente y te ayudaremos rápido.
                    </p>
                    <a
                      href="https://wa.me/50360505363?text=Hola,%20necesito%20ayuda%20con%20mi%20cuenta%20de%20ConfirMaterial"
                      target="_blank"
                      class="btn btn-outline border-green-500 text-green-600 hover:bg-green-500 hover:text-white hover:border-green-500 w-full"
                    >
                      <Icon name="mdi:whatsapp" class="w-5 h-5 mr-1" />
                      Contactar por WhatsApp
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <script>
      // Populate fields from Zustand localStorage if they are empty
      document.addEventListener("DOMContentLoaded", () => {
        const firstNameInput = document.getElementById(
          "firstNameInput",
        ) as HTMLInputElement;
        const lastNamesInput = document.getElementById(
          "lastNamesInput",
        ) as HTMLInputElement;
        const birthDateInput = document.getElementById(
          "birthDateInput",
        ) as HTMLInputElement;

        const dashboardTitle = document.getElementById("dashboardTitle");
        const dashboardCredential = document.getElementById(
          "dashboardCredential",
        );

        if (firstNameInput && !firstNameInput.value) {
          const storeStr = localStorage.getItem("progress-storage");
          if (storeStr) {
            try {
              const store = JSON.parse(storeStr).state;
              if (store && store.user) {
                firstNameInput.value = store.user.firstName || "";
                lastNamesInput.value = store.user.lastName || "";
                if (store.user.birthDate)
                  birthDateInput.value = store.user.birthDate;

                if (dashboardTitle && store.user.firstName) {
                  dashboardTitle.textContent = `Hola, ${store.user.firstName}`;
                }
                if (dashboardCredential && store.user.credential) {
                  dashboardCredential.textContent = `Credencial: ${store.user.credential}`;
                }
              }
            } catch (e) {}
          }
        }
      });

      // Remover toasts automáticamente después de 3 segundos
      setTimeout(() => {
        const toasts = document.querySelectorAll(".toast");
        toasts.forEach((toast) => {
          toast.classList.add(
            "opacity-0",
            "transition-opacity",
            "duration-500",
          );
          setTimeout(() => toast.remove(), 500);
        });

        // Limpiar URL
        if (window.history.replaceState) {
          const url = new URL(window.location.href);
          url.searchParams.delete("success");
          url.searchParams.delete("error");
          window.history.replaceState({ path: url.href }, "", url.href);
        }
      }, 3000);
    </script>
  </body>
</html>
