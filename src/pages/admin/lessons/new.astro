---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import LessonEditor from '../../../components/react/admin/LessonEditor';

import { supabase } from '../../../utils/supabase';

// This is admin area, we must check auth and role
const { cookies } = Astro;
const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
    return Astro.redirect('/login');
}

// Set session
await supabase.auth.setSession({
  access_token: accessToken.value,
  refresh_token: refreshToken.value,
});

const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

const { data: profile } = await supabase
    .from('profiles')
    .select('role')
    .eq('id', user.id)
    .single();

if (!profile || profile.role !== 'teacher') {
    return Astro.redirect('/dashboard?error=Acceso+Denegado');
}
---

<html lang="es" data-theme="confirtheme">
<head>
    <BaseHead title="Nueva Lección" description="Crear nueva lección" />
</head>
<body class="min-h-screen bg-base-100 flex flex-col">
    <Header isAdminMode={true} />
    <main class="flex-grow container mx-auto px-4 py-8">
        <div class="mb-8">
            <h1 class="text-3xl font-black mb-2">Crear Nueva Lección</h1>
            <p class="text-base-content/70">Completa los bloques a continuación. El sistema generará el archivo MDX y el JSON correspondientes automáticamente.</p>
        </div>

        <LessonEditor client:only="react" />
    </main>
    <Footer />
</body>
</html>
