---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

import { supabase } from '../../../utils/supabase';
import { createClient } from '@supabase/supabase-js';

const supabaseAdmin = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
  { auth: { persistSession: false } }
);

// This is admin area, we must check auth and role
const { cookies } = Astro;
const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
    return Astro.redirect('/login');
}

// Set session
await supabase.auth.setSession({
  access_token: accessToken.value,
  refresh_token: refreshToken.value,
});

const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

const { data: profile } = await supabaseAdmin
    .from('profiles')
    .select('role')
    .eq('id', user.id)
    .single();

if (!profile || (profile.role !== 'teacher' && profile.role !== 'admin')) {
    return Astro.redirect('/dashboard?error=Acceso+Denegado');
}

const lessons = (await getCollection('lessons')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<html lang="es" data-theme="confirtheme">
<head>
    <BaseHead title="Panel de Lecciones" description="Administración de Lecciones" />
</head>
<body class="min-h-screen bg-base-100 flex flex-col">
    <Header isAdminMode={true} />
    <main class="flex-grow container mx-auto px-2 sm:px-4 py-8 max-w-5xl">
        <div class="flex justify-between items-center mb-6 sm:mb-8 px-2 sm:px-0 gap-4">
            <div>
                <h1 class="text-2xl sm:text-3xl font-black">Panel de Lecciones</h1>
                <p class="text-base-content/70 text-xs sm:text-base">Crea, edita y gestiona el contenido de las lecciones.</p>
            </div>
            <div class="flex gap-2">
                <button onclick="window.location.reload()" class="btn btn-outline btn-sm sm:btn-md shrink-0">
                    <Icon name="mdi:refresh" class="w-4 h-4 sm:w-5 sm:h-5 sm:mr-1" />
                    <span class="hidden sm:inline">Recargar</span>
                </button>
                <a href="/admin/lessons/new" class="btn btn-primary btn-sm sm:btn-md shrink-0">
                    <Icon name="mdi:plus" class="w-4 h-4 sm:w-5 sm:h-5 mr-0.5 sm:mr-1" />
                    <span class="hidden sm:inline">Nueva</span>
                </a>
            </div>
        </div>

        <div class="bg-base-200 rounded-box p-2 sm:p-4 shadow-sm">
            
            {/* Search Input */}
            <div class="mb-4">
                <div class="join w-full sm:w-80">
                    <input 
                        type="text" 
                        id="searchInput" 
                        placeholder="Buscar lecciones por título, autor o ID..." 
                        class="input input-bordered join-item w-full"
                    />
                    <button class="btn join-item btn-square" aria-label="Buscar">
                        <Icon name="mdi:magnify" class="w-5 h-5" />
                    </button>
                </div>
            </div>

            {/* Desktop View: Table */}
            <div class="overflow-x-auto hidden md:block">
                <table class="table w-full" id="lessonsTable">
                    <thead>
                        <tr>
                            <th class="cursor-pointer hover:bg-base-300 transition-colors" data-sort="id">ID <Icon name="mdi:swap-vertical" class="inline w-3 h-3" /></th>
                            <th class="cursor-pointer hover:bg-base-300 transition-colors" data-sort="title">Título <Icon name="mdi:swap-vertical" class="inline w-3 h-3" /></th>
                            <th class="cursor-pointer hover:bg-base-300 transition-colors" data-sort="author">Autor <Icon name="mdi:swap-vertical" class="inline w-3 h-3" /></th>
                            <th class="cursor-pointer hover:bg-base-300 transition-colors" data-sort="date">Fecha <Icon name="mdi:swap-vertical" class="inline w-3 h-3" /></th>
                            <th class="cursor-pointer hover:bg-base-300 transition-colors" data-sort="status">Estado <Icon name="mdi:swap-vertical" class="inline w-3 h-3" /></th>
                            <th class="text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="lessonsTableBody">
                        {lessons.map((lesson) => (
                            <tr class="hover lesson-row" 
                                data-id={lesson.data.lessonId || lesson.id} 
                                data-title={lesson.data.title.toLowerCase()} 
                                data-author={(lesson.data.author || 'Sin autor').toLowerCase()}
                                data-date={new Date(lesson.data.pubDate).getTime()}
                                data-status={lesson.data.draft ? 'borrador' : 'publicada'}
                            >
                                <td><span class="font-mono text-sm">{lesson.data.lessonId || lesson.id}</span></td>
                                <td class="font-bold">{lesson.data.title}</td>
                                <td>{lesson.data.author || 'Sin autor'}</td>
                                <td>
                                    <div class="whitespace-nowrap">{new Date(lesson.data.pubDate).toLocaleDateString('es-ES')}</div>
                                </td>
                                <td>
                                    {lesson.data.draft ? (
                                        <span class="badge badge-warning badge-sm whitespace-nowrap">Borrador (Oculta)</span>
                                    ) : (
                                        <span class="badge badge-success badge-sm text-white whitespace-nowrap">Publicada</span>
                                    )}
                                </td>
                                <td class="text-right flex justify-end gap-2">
                                    <a href={`/lessons/${lesson.id}`} target="_blank" class="btn btn-ghost btn-xs btn-square" title="Ver lección">
                                        <Icon name="mdi:eye" class="w-4 h-4" />
                                    </a>
                                    <a href={`/admin/lessons/edit/${lesson.id}`} class="btn btn-ghost btn-xs btn-square text-primary" title="Editar lección">
                                        <Icon name="mdi:pencil" class="w-4 h-4" />
                                    </a>
                                    <button 
                                        class="btn btn-ghost btn-xs btn-square text-error" 
                                        title="Eliminar lección"
                                        onclick={`if(confirm('¿Seguro que deseas eliminar esta lección? Esta acción es irreversible.')) deleteLesson('${lesson.data.lessonId}', '${lesson.id}')`}
                                    >
                                        <Icon name="mdi:trash-can" class="w-4 h-4" />
                                    </button>
                                </td>
                            </tr>
                        ))}
                        {lessons.length === 0 && (
                            <tr id="emptyRow">
                                <td colspan="6" class="text-center py-8 text-base-content/50">
                                    No hay lecciones creadas todavía.
                                </td>
                            </tr>
                        )}
                        <tr id="noResultsRow" class="hidden">
                            <td colspan="6" class="text-center py-8 text-base-content/50">
                                No se encontraron lecciones que coincidan con la búsqueda.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            {/* Mobile View: Cards */}
            <div class="grid grid-cols-1 gap-3 md:hidden" id="lessonsMobileList">
                {lessons.map((lesson) => (
                    <div class="bg-base-100 p-3.5 rounded-xl border border-base-300 flex flex-col gap-3 shadow-sm lesson-card"
                         data-id={lesson.data.lessonId || lesson.id} 
                         data-title={lesson.data.title.toLowerCase()} 
                         data-author={(lesson.data.author || 'Sin autor').toLowerCase()}
                    >
                        <div class="flex justify-between items-start gap-2">
                            <div>
                                <span class="font-mono text-[10px] text-base-content/55 uppercase tracking-wider">ID: {lesson.data.lessonId || lesson.id}</span>
                                <h3 class="font-bold text-sm text-base-content leading-tight mt-0.5">{lesson.data.title}</h3>
                                <p class="text-xs text-base-content/70 mt-1 flex items-center gap-1">
                                    <Icon name="mdi:account" class="w-3.5 h-3.5"/> 
                                    {lesson.data.author || 'Sin autor'}
                                </p>
                            </div>
                            {lesson.data.draft ? (
                                <span class="badge badge-warning badge-xs shrink-0">Borrador</span>
                            ) : (
                                <span class="badge badge-success badge-xs text-white shrink-0">Publicada</span>
                            )}
                        </div>
                        <div class="flex justify-between items-center border-t border-base-200/60 pt-2.5">
                            <div>
                                <div class="text-[11px] text-base-content/55 font-medium">{new Date(lesson.data.pubDate).toLocaleDateString('es-ES')}</div>
                            </div>
                            <div class="flex gap-1.5">
                                <a href={`/lessons/${lesson.id}`} target="_blank" class="btn btn-ghost btn-sm btn-square" title="Ver lección">
                                    <Icon name="mdi:eye" class="w-4 h-4 text-base-content/70" />
                                </a>
                                <a href={`/admin/lessons/edit/${lesson.id}`} class="btn btn-ghost btn-sm btn-square text-primary" title="Editar lección">
                                    <Icon name="mdi:pencil" class="w-4 h-4" />
                                </a>
                                <button 
                                    class="btn btn-ghost btn-sm btn-square text-error" 
                                    title="Eliminar lección"
                                    onclick={`if(confirm('¿Seguro que deseas eliminar esta lección? Esta acción es irreversible.')) deleteLesson('${lesson.data.lessonId}', '${lesson.id}')`}
                                >
                                    <Icon name="mdi:trash-can" class="w-4 h-4" />
                                </button>
                            </div>
                        </div>
                    </div>
                ))}
                {lessons.length === 0 && (
                    <div class="text-center py-8 text-base-content/50 bg-base-100 rounded-xl border border-base-300">
                        No hay lecciones creadas todavía.
                    </div>
                )}
                <div id="noResultsCard" class="hidden text-center py-8 text-base-content/50 bg-base-100 rounded-xl border border-base-300">
                    No se encontraron lecciones que coincidan con la búsqueda.
                </div>
            </div>
        </div>
    </main>
    <Footer />

    <script is:inline>
        async function deleteLesson(id, slug) {
            try {
                const res = await fetch(`/api/admin/lessons?id=${id}&slug=${slug}`, {
                    method: 'DELETE'
                });
                const data = await res.json();
                if (data.success) {
                    alert('Lección eliminada correctamente.');
                    window.location.reload();
                } else {
                    alert('Error: ' + data.error);
                }
            } catch (err) {
                console.error(err);
                alert('Ocurrió un error de red.');
            }
        }

        // Search and Sort Logic
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('searchInput');
            
            // Search logic
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    const term = e.target.value.toLowerCase();
                    
                    // Filter table rows
                    const rows = document.querySelectorAll('.lesson-row');
                    let visibleRows = 0;
                    rows.forEach(row => {
                        const id = row.getAttribute('data-id') || '';
                        const title = row.getAttribute('data-title') || '';
                        const author = row.getAttribute('data-author') || '';
                        
                        if (id.includes(term) || title.includes(term) || author.includes(term)) {
                            row.style.display = '';
                            visibleRows++;
                        } else {
                            row.style.display = 'none';
                        }
                    });
                    
                    const noResultsRow = document.getElementById('noResultsRow');
                    if (noResultsRow) {
                        noResultsRow.style.display = (visibleRows === 0 && rows.length > 0) ? '' : 'none';
                    }

                    // Filter mobile cards
                    const cards = document.querySelectorAll('.lesson-card');
                    let visibleCards = 0;
                    cards.forEach(card => {
                        const id = card.getAttribute('data-id') || '';
                        const title = card.getAttribute('data-title') || '';
                        const author = card.getAttribute('data-author') || '';
                        
                        if (id.includes(term) || title.includes(term) || author.includes(term)) {
                            card.style.display = '';
                            visibleCards++;
                        } else {
                            card.style.display = 'none';
                        }
                    });

                    const noResultsCard = document.getElementById('noResultsCard');
                    if (noResultsCard) {
                        noResultsCard.style.display = (visibleCards === 0 && cards.length > 0) ? 'block' : 'none';
                    }
                });
            }

            // Sort logic
            const tableHeaders = document.querySelectorAll('th[data-sort]');
            let currentSort = { column: 'date', asc: false };

            tableHeaders.forEach(th => {
                th.addEventListener('click', () => {
                    const column = th.getAttribute('data-sort');
                    const isAsc = currentSort.column === column ? !currentSort.asc : true;
                    currentSort = { column, asc: isAsc };
                    
                    const tbody = document.getElementById('lessonsTableBody');
                    const rows = Array.from(tbody.querySelectorAll('.lesson-row'));
                    
                    rows.sort((a, b) => {
                        let valA = a.getAttribute(`data-${column}`);
                        let valB = b.getAttribute(`data-${column}`);
                        
                        if (column === 'date' || column === 'id') {
                            valA = Number(valA) || 0;
                            valB = Number(valB) || 0;
                            return isAsc ? valA - valB : valB - valA;
                        } else {
                            return isAsc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                        }
                    });
                    
                    rows.forEach(row => tbody.appendChild(row));
                });
            });
        });
    </script>
</body>
</html>
