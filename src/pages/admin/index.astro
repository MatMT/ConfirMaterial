---
export const prerender = false;
import BaseLayout from '../../layouts/LessonPost.astro';
import { createClient } from "@supabase/supabase-js";
import StudentsTable from '../../components/react/admin/StudentsTable';

// Inicializar cliente admin para saltar RLS
const supabaseAdmin = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
    { auth: { persistSession: false } }
);

// Verificar el PIN desde las cookies
const adminPinCookie = Astro.cookies.get('admin-pin')?.value;
const correctPin = import.meta.env.ADMIN_PIN?.replace(/['"]/g, '') || "1234"; // Evitar problemas con comillas en el .env

// Si es un POST (login), verificamos el PIN
if (Astro.request.method === "POST") {
    let formData;
    try {
        formData = await Astro.request.formData();
        const pin = formData.get("pin")?.toString();
        console.log(`[Admin] Try Login. Received: ${pin}, Expected: ${correctPin}`);
        if (pin === correctPin) {
            console.log("[Admin] PIN Correct. Setting cookie and redirecting.");
            Astro.cookies.set('admin-pin', pin, { path: '/', httpOnly: true, secure: import.meta.env.PROD, sameSite: 'lax', maxAge: 60 * 60 * 24 });
            return Astro.redirect('/admin');
        } else {
            console.log("[Admin] PIN Incorrect!");
        }
    } catch (e) {
        console.error("[Admin] Error in POST:", e);
    }
}

const isAuthenticated = adminPinCookie === correctPin;

// Obtener la lista de alumnos
let students = [];
if (isAuthenticated) {
    const { data, error } = await supabaseAdmin
        .from('profiles')
        .select('*')
        .eq('role', 'student')
        .order('created_at', { ascending: false });
    
    if (data) {
        // Obtener la última lección para cada alumno
        const { data: streaksData } = await supabaseAdmin
            .from('user_streaks')
            .select('*');
        
        // Unir datos
        students = data.map(student => {
            const streak = streaksData?.find(s => s.user_id === student.id);
            return {
                ...student,
                streak: streak?.current_streak || 0,
                last_connection: streak?.last_lesson_date || student.created_at
            };
        });
    }
}
---
<!DOCTYPE html>
<html lang="es" data-theme="lofi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración</title>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.7.2/dist/full.min.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-base-200 min-h-screen">
    
    <div class="navbar bg-base-100 shadow-sm mb-8">
        <div class="flex-1">
            <a href="/" class="btn btn-ghost text-xl">🏠 Inicio</a>
            <span class="text-xl font-bold ml-4">Panel de Administración</span>
        </div>
        {isAuthenticated && (
            <div class="flex-none">
                <a href="/admin/students/new" class="btn btn-primary">Crear Alumno</a>
            </div>
        )}
    </div>

    <main class="container mx-auto px-4 max-w-6xl">
        {!isAuthenticated ? (
            <div class="max-w-md mx-auto bg-base-100 p-8 rounded-xl shadow-lg mt-20">
                <h1 class="text-2xl font-bold text-center mb-6">Acceso Restringido</h1>
                <form method="POST" class="flex flex-col gap-4">
                    <div class="form-control">
                        <label class="label"><span class="label-text">PIN de Administrador</span></label>
                        <input type="password" name="pin" class="input input-bordered text-center text-2xl tracking-widest" maxLength="4" required placeholder="••••" />
                    </div>
                    <button type="submit" class="btn btn-primary w-full">Ingresar</button>
                </form>
            </div>
        ) : (
            <div>
                <div class="flex justify-between items-end mb-6">
                    <h2 class="text-3xl font-bold">Listado de Alumnos</h2>
                </div>
                
                <div className="bg-base-100 rounded-xl shadow-md p-4">
                    <StudentsTable client:load students={students} />
                </div>
            </div>
        )}
    </main>

</body>
</html>
