---
export const prerender = false;
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { createClient } from "@supabase/supabase-js";
import StudentsTable from '../../components/react/admin/StudentsTable';
import { Icon } from 'astro-icon/components';

// Inicializar cliente admin para saltar RLS
const supabaseAdmin = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
    { auth: { persistSession: false } }
);

// Verificar el PIN desde las cookies
const adminPinCookie = Astro.cookies.get('admin-pin')?.value;
const correctPin = import.meta.env.ADMIN_PIN?.replace(/['"]/g, '') || "1234";

if (Astro.request.method === "POST") {
    let formData;
    try {
        formData = await Astro.request.formData();
        const pin = formData.get("pin")?.toString();
        if (pin === correctPin) {
            console.log("[Admin] PIN Correct. Setting cookie and redirecting.");
            Astro.cookies.set('admin-pin', pin, { path: '/', httpOnly: true, secure: import.meta.env.PROD, sameSite: 'lax', maxAge: 60 * 60 * 24 });
            return Astro.redirect('/admin');
        }
    } catch (e) {
        console.error("[Admin] Error in POST:", e);
    }
}

const isAuthenticated = adminPinCookie === correctPin;

let students = [];
if (isAuthenticated) {
    const { data, error } = await supabaseAdmin
        .from('profiles')
        .select('*')
        .eq('role', 'student')
        .order('created_at', { ascending: false });
    
    if (data) {
        const { data: streaksData } = await supabaseAdmin
            .from('user_streaks')
            .select('*');
        
        students = data.map(student => {
            const streak = streaksData?.find(s => s.user_id === student.id);
            return {
                ...student,
                streak: streak?.current_streak || 0,
                last_connection: streak?.last_lesson_date || student.created_at
            };
        });
    }
}
---

<!DOCTYPE html>
<html lang="es" data-theme="confirtheme">
<head>
    <BaseHead title="Panel de Administración" description="Administración de alumnos" />
</head>
<body class="bg-base-200 min-h-screen flex flex-col font-sans">
    
    <Header />

    <main class="container mx-auto px-4 max-w-6xl flex-grow py-12 animate-fade-up">
        {!isAuthenticated ? (
            <div class="max-w-md mx-auto bg-base-100 p-8 rounded-3xl shadow-2xl mt-20 border border-base-200 backdrop-blur-xl">
                <div class="flex justify-center mb-6">
                    <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center text-primary">
                        <Icon name="mdi:shield-lock-outline" class="w-8 h-8" />
                    </div>
                </div>
                <h1 class="text-3xl font-extrabold text-center mb-2">Acceso Restringido</h1>
                <p class="text-center text-base-content/60 mb-8">Ingresa el PIN de administrador para continuar.</p>
                <form method="POST" class="flex flex-col gap-6">
                    <div class="form-control">
                        <input type="password" name="pin" class="input input-bordered input-lg text-center text-3xl tracking-widest bg-base-200/50 focus:bg-base-100 transition-colors rounded-2xl" maxLength="4" required placeholder="••••" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg rounded-2xl shadow-lg hover:shadow-xl hover:scale-105 transition-all">
                        Ingresar al Panel
                        <Icon name="mdi:arrow-right" class="w-5 h-5 ml-2" />
                    </button>
                </form>
            </div>
        ) : (
            <div class="space-y-8">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 bg-base-100 p-8 rounded-3xl shadow-xl border border-base-200">
                    <div>
                        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary font-bold text-sm mb-4">
                            <Icon name="mdi:shield-check" class="w-4 h-4" />
                            Modo Administrador
                        </div>
                        <h2 class="text-4xl font-extrabold tracking-tight">Gestión de Alumnos</h2>
                        <p class="text-base-content/60 mt-2 text-lg">Supervisa el progreso y las rachas de todos los estudiantes.</p>
                    </div>
                    <a href="/admin/students/new" class="btn btn-primary shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all rounded-full px-8">
                        <Icon name="mdi:account-plus-outline" class="w-5 h-5 mr-2" />
                        Crear Nuevo Alumno
                    </a>
                </div>
                
                <div className="bg-base-100 rounded-3xl shadow-2xl p-6 md:p-8 border border-base-200">
                    <StudentsTable client:load students={students} />
                </div>
            </div>
        )}
    </main>

    <Footer />
</body>
</html>
