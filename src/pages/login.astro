---
export const prerender = false;
import BaseHead from "../components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { supabase } from "../utils/supabase";
import { createClient } from "@supabase/supabase-js";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const serviceRoleKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;

const supabaseAdmin = createClient(supabaseUrl, serviceRoleKey, {
  auth: { autoRefreshToken: false, persistSession: false }
});

const { cookies, redirect, url } = Astro;
const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");
const credential = url.searchParams.get("credential");
const isRegistered = url.searchParams.get("registered") === "true";
const isTeacherRegistered =
  url.searchParams.get("teacher_registered") === "true";
const errorMsg = url.searchParams.get("error");

if (accessToken && refreshToken) {
  await supabase.auth.setSession({
    access_token: accessToken.value,
    refresh_token: refreshToken.value,
  });
  const { data: { user } } = await supabase.auth.getUser();
  if (user) {
    const { data: profile } = await supabaseAdmin
      .from('profiles')
      .select('role')
      .eq('id', user.id)
      .single();
    if (profile && (profile.role === 'teacher' || profile.role === 'admin')) {
      return redirect("/admin");
    }
  }
  return redirect("/dashboard");
}
---

<!doctype html>
<html lang="es" data-theme="confirtheme">
  <head>
    <BaseHead
      title={`Iniciar Sesión | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />
  </head>
  <body
    class="min-h-screen bg-base-200 flex flex-col justify-center items-center p-4"
  >
    <div
      class="toast toast-top toast-end z-[100] w-full max-w-md"
      id="successToast"
    >
      {
        isRegistered && credential && (
          <div class="alert alert-success shadow-2xl flex justify-between rounded-lg text-white border-none">
            <div class="flex items-start gap-3">
              <div>
                <h3 class="font-bold text-white">¡Cuenta creada!</h3>
                <div class="text-sm mt-1 text-white">
                  Tu credencial es:{" "}
                  <strong class="text-xl">{credential}</strong>
                </div>
                <div class="text-xs mt-1 text-white/90">
                  Guárdala bien. Ya puedes iniciar sesión.
                </div>
              </div>
            </div>
            <button
              class="btn btn-ghost btn-sm btn-circle text-white"
              onclick="document.getElementById('successToast').style.display='none'"
            >
              ✕
            </button>
          </div>
        )
      }

      {
        errorMsg && (
          <div class="alert alert-error shadow-2xl flex justify-between rounded-lg text-white border-none">
            <div class="flex items-start gap-3">
              <div>
                <h3 class="font-bold text-white">Error al iniciar sesión</h3>
                <div class="text-sm mt-1 text-white">
                  {errorMsg === "Invalid login credentials"
                    ? "Credencial o contraseña incorrecta"
                    : errorMsg === "Email not confirmed"
                    ? "Tu cuenta aún no está confirmada. Por favor revisa tu bandeja de entrada o carpeta de spam y haz clic en el enlace de confirmación."
                    : errorMsg}
                </div>
              </div>
            </div>
            <button
              class="btn btn-ghost btn-sm btn-circle text-white"
              onclick="document.getElementById('successToast').style.display='none'"
            >
              ✕
            </button>
          </div>
        )
      }
    </div>

    {
      isTeacherRegistered && (
        <dialog class="modal modal-open bg-black/60 backdrop-blur-sm z-[200]">
          <div class="modal-box bg-base-100 max-w-lg p-8 animate-fade-down">
              <div class="flex flex-col items-center text-center space-y-4">
                  <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                  </div>
                  <h3 class="font-black text-2xl">¡Casi listo!</h3>
                  <p class="text-base-content/80 text-lg">
                      Hemos enviado un enlace de confirmación a tu correo electrónico.
                  </p>
                  <div class="bg-base-200 p-4 rounded-xl text-sm text-left w-full border border-base-300">
                      <p class="font-semibold flex items-center gap-2 mb-1">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                          Paso obligatorio
                      </p>
                      <p class="text-base-content/70">
                          Por favor, revisa tu bandeja de entrada o la carpeta de <strong class="text-base-content">Spam/Correo no deseado</strong>. Debes hacer clic en el enlace de confirmación en el correo antes de poder iniciar sesión en tu panel.
                      </p>
                  </div>
                  
                  <div class="modal-action w-full mt-6">
                      <a href="/login" class="btn btn-primary w-full shadow-lg">Ya confirmé mi correo, Iniciar Sesión</a>
                  </div>
              </div>
          </div>
        </dialog>
      )
    }


    <div
      class="card w-full max-w-sm shadow-2xl bg-base-100 animate-fade-down animate-duration-500"
    >
      <div class="card-body">
        <div class="text-center mb-6">
          <h1 class="text-3xl font-bold text-primary">Bienvenid@</h1>
          <p class="text-sm text-base-content/70 mt-2">
            Ingresa a tu cuenta para continuar aprendiendo
          </p>
        </div>

        <form
          action="/api/auth/signin"
          method="post"
          class="flex flex-col gap-4 relative z-10"
        >
          <div class="form-control">
            <label class="label" for="identifier">
              <span class="label-text font-semibold"
                >Credencial de Alumno o Correo</span
              >
            </label>
            <input
              type="text"
              name="identifier"
              id="identifier"
              value={credential || ""}
              placeholder="EL231027 o tu@correo.com"
              class="input input-bordered w-full"
              required
            />
          </div>

          <div class="form-control">
            <label class="label" for="password">
              <span class="label-text font-semibold">Contraseña</span>
            </label>
            <input
              type="password"
              name="password"
              id="password"
              placeholder="••••••••"
              class="input input-bordered w-full"
              required
            />
            <label class="label mt-1">
              <a href="#" class="label-text-alt link link-hover text-primary"
                >¿Olvidaste tu contraseña?</a
              >
            </label>
          </div>

          <div class="form-control mt-4">
            <button type="submit" class="btn btn-primary w-full"
              >Iniciar Sesión</button
            >
          </div>
        </form>

        <div class="divider my-6">o</div>

        <p class="text-center text-sm">
          ¿No tienes una cuenta? <a
            href="/register"
            class="link link-primary font-semibold">Regístrate aquí</a
          >
        </p>
      </div>
    </div>
    <script>
      // Populate credential from Zustand localStorage if empty
      document.addEventListener("DOMContentLoaded", () => {
        const identifierInput = document.getElementById(
          "identifier",
        ) as HTMLInputElement;
        if (identifierInput && !identifierInput.value) {
          const storeStr = localStorage.getItem("progress-storage");
          if (storeStr) {
            try {
              const store = JSON.parse(storeStr).state;
              if (store && store.user && store.user.credential) {
                identifierInput.value = store.user.credential;
              }
            } catch (e) {}
          }
        }

        // Remove error toast from URL after a delay
        setTimeout(() => {
          if (window.history.replaceState) {
            const url = new URL(window.location.href);
            if (url.searchParams.has("error")) {
              url.searchParams.delete("error");
              window.history.replaceState({ path: url.href }, "", url.href);
            }
          }
        }, 3000);
      });
    </script>
  </body>
</html>
