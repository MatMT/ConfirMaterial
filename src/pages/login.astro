---
import BaseHead from "../components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

const { cookies, redirect, url } = Astro;
const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");
const credential = url.searchParams.get("credential");
const isRegistered = url.searchParams.get("registered") === "true";
const isTeacherRegistered =
  url.searchParams.get("teacher_registered") === "true";
const errorMsg = url.searchParams.get("error");

if (accessToken && refreshToken) {
  return redirect("/dashboard");
}
---

<!doctype html>
<html lang="es" data-theme="confirtheme">
  <head>
    <BaseHead
      title={`Iniciar Sesión | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />
  </head>
  <body
    class="min-h-screen bg-base-200 flex flex-col justify-center items-center p-4"
  >
    <div
      class="toast toast-top toast-end z-[100] w-full max-w-md"
      id="successToast"
    >
      {
        isRegistered && credential && (
          <div class="alert alert-success shadow-2xl flex justify-between rounded-lg text-white border-none">
            <div class="flex items-start gap-3">
              <div>
                <h3 class="font-bold text-white">¡Cuenta creada!</h3>
                <div class="text-sm mt-1 text-white">
                  Tu credencial es:{" "}
                  <strong class="text-xl">{credential}</strong>
                </div>
                <div class="text-xs mt-1 text-white/90">
                  Guárdala bien. Ya puedes iniciar sesión.
                </div>
              </div>
            </div>
            <button
              class="btn btn-ghost btn-sm btn-circle text-white"
              onclick="document.getElementById('successToast').style.display='none'"
            >
              ✕
            </button>
          </div>
        )
      }

      {
        isTeacherRegistered && (
          <div class="alert alert-info shadow-2xl flex justify-between rounded-lg text-white border-none">
            <div class="flex items-start gap-3">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="stroke-white shrink-0 h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
              <div>
                <h3 class="font-bold text-white">¡Registro Exitoso!</h3>
                <div class="text-xs mt-1 text-white/90">
                  Revisa tu correo para confirmar.
                </div>
              </div>
            </div>
            <button
              class="btn btn-ghost btn-sm btn-circle text-white"
              onclick="document.getElementById('successToast').style.display='none'"
            >
              ✕
            </button>
          </div>
        )
      }

      {
        errorMsg && (
          <div class="alert alert-error shadow-2xl flex justify-between rounded-lg text-white border-none">
            <div class="flex items-start gap-3">
              <div>
                <h3 class="font-bold text-white">Error al iniciar sesión</h3>
                <div class="text-sm mt-1 text-white">
                  {errorMsg === "Invalid login credentials"
                    ? "Credencial o contraseña incorrecta"
                    : errorMsg}
                </div>
              </div>
            </div>
            <button
              class="btn btn-ghost btn-sm btn-circle text-white"
              onclick="document.getElementById('successToast').style.display='none'"
            >
              ✕
            </button>
          </div>
        )
      }
    </div>

    <div
      class="card w-full max-w-sm shadow-2xl bg-base-100 animate-fade-down animate-duration-500"
    >
      <div class="card-body">
        <div class="text-center mb-6">
          <h1 class="text-3xl font-bold text-primary">Bienvenid@</h1>
          <p class="text-sm text-base-content/70 mt-2">
            Ingresa a tu cuenta para continuar aprendiendo
          </p>
        </div>

        <form
          action="/api/auth/signin"
          method="post"
          class="flex flex-col gap-4 relative z-10"
        >
          <div class="form-control">
            <label class="label" for="identifier">
              <span class="label-text font-semibold"
                >Credencial de Alumno o Correo</span
              >
            </label>
            <input
              type="text"
              name="identifier"
              id="identifier"
              value={credential || ""}
              placeholder="EL231027 o tu@correo.com"
              class="input input-bordered w-full"
              required
            />
          </div>

          <div class="form-control">
            <label class="label" for="password">
              <span class="label-text font-semibold">Contraseña</span>
            </label>
            <input
              type="password"
              name="password"
              id="password"
              placeholder="••••••••"
              class="input input-bordered w-full"
              required
            />
            <label class="label mt-1">
              <a href="#" class="label-text-alt link link-hover text-primary"
                >¿Olvidaste tu contraseña?</a
              >
            </label>
          </div>

          <div class="form-control mt-4">
            <button type="submit" class="btn btn-primary w-full"
              >Iniciar Sesión</button
            >
          </div>
        </form>

        <div class="divider my-6">o</div>

        <p class="text-center text-sm">
          ¿No tienes una cuenta? <a
            href="/register"
            class="link link-primary font-semibold">Regístrate aquí</a
          >
        </p>
      </div>
    </div>
    <script>
      // Populate credential from Zustand localStorage if empty
      document.addEventListener("DOMContentLoaded", () => {
        const identifierInput = document.getElementById(
          "identifier",
        ) as HTMLInputElement;
        if (identifierInput && !identifierInput.value) {
          const storeStr = localStorage.getItem("progress-storage");
          if (storeStr) {
            try {
              const store = JSON.parse(storeStr).state;
              if (store && store.user && store.user.credential) {
                identifierInput.value = store.user.credential;
              }
            } catch (e) {}
          }
        }

        // Remove error toast from URL after a delay
        setTimeout(() => {
          if (window.history.replaceState) {
            const url = new URL(window.location.href);
            if (url.searchParams.has("error")) {
              url.searchParams.delete("error");
              window.history.replaceState({ path: url.href }, "", url.href);
            }
          }
        }, 3000);
      });
    </script>
  </body>
</html>
