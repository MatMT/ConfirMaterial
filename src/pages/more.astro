---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import QuestionManager from '../components/react/QuestionManager';
---

<html lang="es">
<head>
    <BaseHead title="Materiales Extra" description="Explora contenido adicional para complementar tu aprendizaje"/>
</head>
<body class="bg-base-100 min-h-screen flex flex-col">
    <Header />
    
    <main class="flex-grow w-full py-12">
        <div class="text-center mb-12 animate-fade-up px-4">
            <h1 class="text-4xl md:text-5xl font-extrabold text-base-content mb-4 tracking-tight">Materiales de <span class="text-primary">Apoyo</span></h1>
            <p class="text-base-content/70 max-w-2xl mx-auto text-lg">
                Aquí encontrarás podcasts, libros y recursos adicionales seleccionados especialmente para ti.
            </p>
        </div>

        {/* Bento Grid Layout */}
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 max-w-7xl mx-auto px-2 sm:px-4 w-full">
            
            {/* Card 1: Podcast */}
            <div class="card bg-base-100 shadow-xl border border-base-200 lg:col-span-2 group hover:shadow-2xl transition-all duration-300 animate-fade-right">
                <div class="card-body p-4 sm:p-8">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-12 h-12 rounded-full bg-green-500/10 flex items-center justify-center text-green-600">
                            <Icon name="mdi:spotify" class="w-8 h-8" />
                        </div>
                        <div>
                            <h2 class="card-title text-2xl">Podcast</h2>
                            <p class="text-sm text-base-content/60">¿Qué haría Jesús?</p>
                        </div>
                    </div>
                    
                    <div class="w-full rounded-xl overflow-hidden bg-base-200 shadow-inner">
                        <iframe
                            style="border-radius:12px"
                            src="https://open.spotify.com/embed/show/1FB03zVd6AIWDCwCG2ZUSS/video?utm_source=generator" 
                            width="100%" 
                            height="152" 
                            frameborder="0" 
                            allowfullscreen
                            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                            loading="lazy">
                        </iframe>
                    </div>
                </div>
            </div>

            {/* Card 2: Youcat */}
            <div class="card bg-yellow-400 text-black shadow-xl hover:shadow-2xl transition-all duration-300 animate-fade-left">
                <div class="card-body p-4 sm:p-8">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-12 h-12 rounded-full bg-black flex items-center justify-center shadow-md">
                            <Icon name="mdi:book-open-page-variant" class="w-6 h-6 text-white" />
                        </div>
                        <div>
                            <h2 class="card-title text-2xl font-black">Youcat</h2>
                            <p class="text-sm text-black/70 font-semibold">Documento Oficial</p>
                        </div>
                    </div>
                    <p class="text-black/80 font-medium text-sm mb-4">
                        Catecismo joven de la Iglesia Católica. Un recurso fundamental para profundizar en tu fe.
                    </p>
                    <div class="relative w-full aspect-square rounded-xl overflow-hidden bg-black/5 border border-black/10 backdrop-blur-md">
                        <iframe
                            class="absolute top-0 left-0 w-full h-full"
                            src="https://drive.google.com/file/d/1jWUoAuU7nmLipBMY5tDEtBO-MLPFEzUO/preview" 
                            allow="autoplay">
                        </iframe>
                    </div>
                </div>
            </div>

            {/* Card 3: Formulario de Preguntas */}
            <QuestionManager client:load />

        </div>
    </main>
    
    <Footer />

    <style>
        @keyframes fade-up {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fade-right {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes fade-left {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes fade-in {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .animate-fade-up { animation: fade-up 0.6s ease-out forwards; }
        .animate-fade-right { animation: fade-right 0.6s ease-out forwards; }
        .animate-fade-left { animation: fade-left 0.6s ease-out forwards; }
        .animate-fade-in { animation: fade-in 0.3s ease-out forwards; }
    </style>
</body>
</html>
