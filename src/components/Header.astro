---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
import { Icon } from 'astro-icon/components';
import StoreInitializer from './react/StoreInitializer';
import StreakDisplay from './react/StreakDisplay';
import { supabase } from '../utils/supabase';
import { createClient } from "@supabase/supabase-js";

const supabaseAdmin = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
  { auth: { persistSession: false } }
);

interface Props {
  isSticky?: boolean;
  isAdminMode?: boolean;
}

const { isSticky = true, isAdminMode = false } = Astro.props;
const { cookies } = Astro;
const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");
const isLoggedIn = !!accessToken;

let userProfile = null;
if (isLoggedIn) {
  // Opcional: Obtener perfil del usuario para inicializar Zustand
  // Como esto corre en SSR, le pasaremos los datos básicos si existen
  try {
    const { data: { user } } = await supabase.auth.getUser(accessToken.value);
    if (user) {
      userProfile = { id: user.id }; // Garantizar que el ID siempre esté
      const { data: profile } = await supabaseAdmin.from('profiles').select('*').eq('id', user.id).single();
      if (profile) {
          userProfile = { ...userProfile, ...profile };
      }
    }
  } catch (e) {}
}
---

<header class={`navbar bg-base-100 shadow-sm ${isSticky ? 'sticky top-0 z-[100]' : 'relative z-[100]'}`}>
  <StoreInitializer client:only="react" user={userProfile} accessToken={accessToken?.value} refreshToken={refreshToken?.value} />
  
  <div class="navbar-start">
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost md:hidden">
        <Icon name="mdi:menu" class="h-6 w-6" />
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
        {isAdminMode ? (
          <>
            <li><HeaderLink href="/admin">👥 Alumnos</HeaderLink></li>
            <li><HeaderLink href="/admin/lessons">📝 Editar Lecciones</HeaderLink></li>
          </>
        ) : (
          <>
            <li><HeaderLink href="/">Inicio</HeaderLink></li>
            <li><HeaderLink href="/lessons">Lecciones</HeaderLink></li>
            <li><HeaderLink href="/more">Material</HeaderLink></li>
          </>
        )}
      </ul>
    </div>
    <a href={isAdminMode ? "/admin" : "/"} class="btn btn-ghost text-lg sm:text-xl font-bold text-primary px-2 sm:px-4">
      {SITE_TITLE} {isAdminMode && <span class="text-[10px] sm:text-xs ml-1 bg-primary/10 text-primary px-2 py-0.5 rounded-full uppercase tracking-wider hidden sm:inline-block">Admin</span>}
    </a>
  </div>
  
  <div class="navbar-center hidden md:flex">
    <ul class="menu menu-horizontal px-1">
      {isAdminMode ? (
        <>
          <li><HeaderLink href="/admin"><Icon name="mdi:account-group" class="w-4 h-4 mr-1"/> Alumnos</HeaderLink></li>
          <li><HeaderLink href="/admin/lessons"><Icon name="mdi:file-document-edit" class="w-4 h-4 mr-1"/> Lecciones</HeaderLink></li>
        </>
      ) : (
        <>
          <li><HeaderLink href="/">Inicio</HeaderLink></li>
          <li><HeaderLink href="/lessons">Lecciones</HeaderLink></li>
          <li><HeaderLink href="/more">Material</HeaderLink></li>
        </>
      )}
    </ul>
  </div>
  
  <div class="navbar-end flex items-center">
    {!isAdminMode && isLoggedIn && <StreakDisplay client:only="react" />}
    {isAdminMode ? (
      <a href="/" class="btn btn-outline btn-primary btn-sm rounded-full gap-1 px-2.5 md:px-4">
        <Icon name="mdi:exit-run" class="h-4 w-4" />
        <span class="hidden md:inline">Salir Admin</span>
      </a>
    ) : isLoggedIn ? (
      <a href="/dashboard" class="btn btn-ghost btn-circle" aria-label="Perfil">
        <Icon name="mdi:account-circle" class="h-8 w-8 text-primary" />
      </a>
    ) : (
      <a href="/login" class="btn btn-outline btn-primary btn-sm rounded-full">
        <Icon name="mdi:login" class="h-4 w-4 mr-1" /> Entrar
      </a>
    )}
  </div>
</header>
<style is:global>
  .menu a {
    border: 1px solid transparent;
    border-radius: 9999px; /* Pill shape */
    margin: 0 0.25rem;
    padding: 0.5rem 1rem;
    transition: all 0.2s ease;
  }
  .menu a.active {
    border-color: var(--fallback-p,oklch(var(--p))) !important;
    color: var(--fallback-p,oklch(var(--p))) !important;
    font-weight: bold !important;
    background-color: transparent !important;
    text-decoration: none !important;
  }
</style>
